{
  "name": "anklo-os",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "arch:check": "node scripts/check-architecture.mjs",
    "deps:check": "pnpm peers check",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "db:generate": "pnpm --filter @anklo/db db:generate",
    "db:validate": "pnpm --filter @anklo/db db:validate",
    "build": "pnpm db:generate && pnpm --filter @anklo/web build",
    "verify": "pnpm format:check && pnpm lint && pnpm arch:check && pnpm deps:check && pnpm db:generate && pnpm typecheck && pnpm test && pnpm db:validate && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "24.10.4",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.1.10"
  }
}
