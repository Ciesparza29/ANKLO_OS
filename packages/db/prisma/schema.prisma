generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

enum CutRequestStatus {
  DRAFT
  SUBMITTED
  CANCELLED
}

enum CutExecutionMode {
  INTERNAL
  EXTERNAL
}

enum CutRequestOperationAction {
  CUT_REQUEST_CREATED
  CUT_REQUEST_SUBMITTED
  CUT_REQUEST_CANCELLED
}

model CutRequest {
  id                 String           @id @default(uuid()) @db.Uuid
  organizationId     String           @map("organization_id") @db.Uuid
  requestingUnit     String           @map("requesting_unit") @db.VarChar(200)
  requester           String           @db.VarChar(200)
  materialOwner       String?          @map("material_owner") @db.VarChar(200)
  currentCustodian    String           @map("current_custodian") @db.VarChar(200)
  executionMode       CutExecutionMode @map("execution_mode")
  expectedExecutor    String?          @map("expected_executor") @db.VarChar(200)
  externalProvider    String?          @map("external_provider") @db.VarChar(200)
  reference            String?          @db.VarChar(120)
  priority             String           @db.VarChar(80)
  requiredAt           DateTime         @map("required_at") @db.Timestamptz(6)
  observations         String?
  status               CutRequestStatus @default(DRAFT)
  version              Int              @default(1)
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy            String           @map("created_by") @db.Uuid
  lines                CutRequestLine[]
  operations           CutRequestOperation[]

  @@unique([organizationId, id])
  @@index([organizationId, status, requiredAt], map: "cut_requests_org_status_required_idx")
  @@index([organizationId, createdAt], map: "cut_requests_org_created_idx")
  @@map("cut_requests")
}

model CutRequestLine {
  id                    String     @id @default(uuid()) @db.Uuid
  organizationId        String     @map("organization_id") @db.Uuid
  cutRequestId           String     @map("cut_request_id") @db.Uuid
  productSpecification  String     @map("product_specification") @db.VarChar(500)
  quantity              Decimal    @db.Decimal
  unit                  String     @db.VarChar(32)
  requestedLength       Decimal    @map("requested_length") @db.Decimal
  tolerance             String?    @db.VarChar(120)
  observation           String?
  position              Int
  createdAt             DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  cutRequest            CutRequest @relation(fields: [organizationId, cutRequestId], references: [organizationId, id], onDelete: Restrict, map: "cut_request_lines_request_fkey")

  @@unique([organizationId, cutRequestId, position], map: "cut_request_lines_org_request_position_key")
  @@index([organizationId, cutRequestId], map: "cut_request_lines_org_request_idx")
  @@map("cut_request_lines")
}

model CutRequestOperation {
  id                 String                    @id @default(uuid()) @db.Uuid
  organizationId     String                    @map("organization_id") @db.Uuid
  clientOperationId  String                    @map("client_operation_id") @db.Uuid
  cutRequestId       String                    @map("cut_request_id") @db.Uuid
  action             CutRequestOperationAction
  createdAt          DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  cutRequest         CutRequest                @relation(fields: [organizationId, cutRequestId], references: [organizationId, id], onDelete: Restrict, map: "cut_request_operations_request_fkey")

  @@unique([organizationId, clientOperationId], map: "cut_request_operations_org_client_key")
  @@index([organizationId, cutRequestId], map: "cut_request_operations_org_request_idx")
  @@map("cut_request_operations")
}

model AuditEvent {
  id              String                    @id @default(uuid()) @db.Uuid
  organizationId  String                    @map("organization_id") @db.Uuid
  actorId          String                    @map("actor_id") @db.Uuid
  entityType       String                    @map("entity_type") @db.VarChar(80)
  entityId         String                    @map("entity_id") @db.Uuid
  action           CutRequestOperationAction
  occurredAt       DateTime                  @map("occurred_at") @db.Timestamptz(6)
  before           Json?
  after            Json
  reason           String?
  correlationId    String                    @map("correlation_id") @db.Uuid
  createdAt        DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([organizationId, entityType, entityId, occurredAt], map: "audit_events_org_entity_occurred_idx")
  @@index([organizationId, correlationId], map: "audit_events_org_correlation_idx")
  @@map("audit_events")
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(200)
  description    String?  @db.VarChar(1000)
  sku            String?  @db.VarChar(120)
  externalCode   String?  @map("external_code") @db.VarChar(120)
  category       String?  @db.VarChar(100)
  manufacturer   String?  @db.VarChar(100)
  baseUnit       String?  @map("base_unit") @db.VarChar(32)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy      String   @map("created_by") @db.Uuid

  @@unique([organizationId, id])
  @@index([organizationId, isActive], map: "products_org_is_active_idx")
  @@map("products")
}
