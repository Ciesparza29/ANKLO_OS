POSTGRES_DB=anklo_os
POSTGRES_USER=anklo
POSTGRES_PASSWORD=local-development-only
DATABASE_URL=postgresql://anklo:local-development-only@localhost:5432/anklo_os
# Contexto ficticio exclusivo de desarrollo local. Producción debe integrar identidad real.
ANKLO_DEV_ACTOR_ID=00000000-0000-4000-8000-000000000001
ANKLO_DEV_ORGANIZATION_ID=00000000-0000-4000-8000-000000000002
# Capacidades ficticias para ejercer el flujo completo en desarrollo; no son asignaciones productivas.
ANKLO_DEV_CUT_REQUEST_CAPABILITIES=cut_request:create,cut_request:read,cut_request:read_history,cut_request:submit,cut_request:cancel
# Abstracción mínima temporal; el catálogo y precisión de unidades siguen pendientes.
ANKLO_CUT_REQUEST_UNITS=MM
